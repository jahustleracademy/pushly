        <string>Pushly Monitor</string>
        <key>type</key>
        <string>device-activity-monitor</string>
        <key>platforms</key>
        <array>
          <string>ios</string>
        </array>
        <key>appGroup</key>
        <string>group.com.pushly.shared</string>
        <key>ios</key>
        <dict>
          <key>deploymentTarget</key>
          <string>16.0</string>
          <key>frameworks</key>
          <array>
            <string>DeviceActivity</string>
            <string>ManagedSettings</string>
            <string>FamilyControls</string>
          </array>
          <key>entitlements</key>
          <dict>
            <key>com.apple.security.application-groups</key>
            <array>
              <string>group.com.pushly.shared</string>
            </array>
            <key>com.apple.developer.family-controls</key>
            <true/>
          </dict>
        </dict>
      </dict>
    </array>
  </dict>
